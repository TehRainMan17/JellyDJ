{
  "manifest_version": 3,
  "name": "JellyDJ Playlist Importer",
  "version": "1.0.0",
  "description": "Send playlists from Spotify, Tidal, or YouTube Music directly to JellyDJ.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://tidal.com/*",
    "https://listen.tidal.com/*",
    "https://music.youtube.com/*",
    "https://www.youtube.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://open.spotify.com/*",
        "https://tidal.com/*",
        "https://listen.tidal.com/*",
        "https://music.youtube.com/*",
        "https://www.youtube.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
