
# ============================================================
# JellyDJ — Environment Variables
# ============================================================
# Copy this file to .env before running docker compose up.
# All sensitive settings (API keys, connection URLs) can be
# set here to pre-seed the database, or left blank and entered
# via the web UI after first launch.
# ============================================================

# ── First-time Setup ──────────────────────────────────────────────────────────
# Set these to bootstrap JellyDJ before you have a Jellyfin connection.
# Once you have logged in and configured Jellyfin on the Connections page,
# REMOVE these variables and restart the stack — the setup login will be
# disabled automatically once Jellyfin is configured.
#
# Use a strong, unique password — treat it like a root password.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(24))"
#
# SETUP_USERNAME=admin
# SETUP_PASSWORD=change-me-use-a-strong-password
#
# Advanced: keep setup login available even after Jellyfin is configured.
# Not recommended for internet-facing instances.
# SETUP_ALLOW_AFTER_CONFIGURE=false

# ── App ──────────────────────────────────────────────────────
# Port JellyDJ listens on your host machine.
# Change this if port 7879 is already in use.
JELLYDJ_PORT=7879

# Timezone for scheduled job times and display.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Secret key used to encrypt stored credentials (Jellyfin key, Lidarr key, etc.)
# Generate a strong value: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: changing this after setup will invalidate all stored credentials —
# you will need to re-enter your API keys in the UI.
SECRET_KEY=change-me-generate-a-real-secret

# JWT signing key — separate from SECRET_KEY so credential encryption and
# token signing use independent keys.  Rotating one does not affect the other.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, falls back to SECRET_KEY (backwards-compatible but not recommended).
# JWT_SECRET_KEY=change-me-generate-a-second-secret

# ── Security ─────────────────────────────────────────────────────────────────

# Webhook shared secret.
#
# JellyDJ requires every inbound Jellyfin webhook to carry this value in the
# X-Jellyfin-Token header.  Without it, any internet host could inject playback
# events and corrupt your listening history and skip-penalty data.
#
# Setup (do this before pointing Jellyfin at the webhook URL):
#   1. Generate a secret:
#        python -c "import secrets; print(secrets.token_urlsafe(32))"
#   2. Paste the result as WEBHOOK_SECRET below.
#   3. In Jellyfin → Dashboard → Plugins → Webhook → your destination,
#      add a header:
#        Name:  X-Jellyfin-Token
#        Value: <same secret>
#
# Until WEBHOOK_SECRET is set, all webhook requests are rejected (HTTP 401).
# WEBHOOK_SECRET=

# Set to "false" only if JellyDJ is on a fully private LAN and you have
# decided not to use a webhook secret.  Not recommended for any deployment
# that is accessible from the internet.
# WEBHOOK_SECRET_REQUIRED=true

# Allowed CORS origins for the frontend.  Leave unset (or set to *) for
# LAN-only / Docker deployments.  Restrict to your domain for internet-facing:
#   CORS_ORIGINS=https://jellydj.yourdomain.com
# CORS_ORIGINS=

# ── Jellyfin ─────────────────────────────────────────────────
# You can pre-seed these or configure them via the Connections page in the UI.
# JELLYFIN_URL=http://your-jellyfin-host:8096
# JELLYFIN_API_KEY=your-jellyfin-api-key

# ── Lidarr ───────────────────────────────────────────────────
# Required only if you want auto-download functionality.
# LIDARR_URL=http://your-lidarr-host:8686
# LIDARR_API_KEY=your-lidarr-api-key

# ── External APIs ─────────────────────────────────────────────
# Optional. Without these, popularity scores fall back to MusicBrainz only.
# Configure via the Settings page in the UI after first launch.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# LASTFM_API_KEY=
# LASTFM_API_SECRET=

# ── Database ──────────────────────────────────────────────────
# SQLite is the default and works well for personal use.
# For multi-user or high-volume deployments you can point this at PostgreSQL:
#   DATABASE_URL=postgresql://user:password@host:5432/jellydj
# Leave as-is for the standard Docker setup.
DATABASE_URL=sqlite:////config/jellydj.db
