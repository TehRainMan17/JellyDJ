        <div className="h-14 flex items-center px-4 border-b border-[#30363d] gap-2.5 flex-shrink-0">
          <div className="w-7 h-7 rounded-lg bg-gradient-to-br from-[#00d4aa] to-[#00a882] flex items-center justify-center flex-shrink-0">
            <Radio size={15} className="text-[#0d1117]" strokeWidth={2.5} />
          </div>
          <span
            className="text-[17px] font-display font-700 tracking-tight text-[#e6edf3]"
            style={{ fontFamily: 'Syne, ui-sans-serif', fontWeight: 700 }}
          >
            JellyDJ
          </span>
        </div>

        {/* Nav */}
        <nav className="flex-1 overflow-y-auto py-3 px-2 space-y-0.5">
          {navItems.map(({ to, icon: Icon, label, badge }) => (
            <NavLink
              key={to}
              to={to}
              className={({ isActive }) =>
                `nav-item ${isActive ? 'active' : ''}`
              }
            >
              <Icon size={16} strokeWidth={1.75} className="flex-shrink-0" />
              <span className="flex-1">{label}</span>
              {badge != null && badge > 0 && (
                <span className="badge">{badge}</span>
              )}
            </NavLink>
          ))}
        </nav>

        {/* Footer */}
        <div className="px-3 py-3 border-t border-[#30363d]">
          <div className="text-[11px] text-[#8b949e] font-mono px-2">v0.1.0</div>
        </div>
      </aside>

      {/* Main content */}
      <main className="flex-1 flex flex-col overflow-hidden">
        {/* Topbar */}
        <header className="h-14 flex-shrink-0 flex items-center px-6 border-b border-[#30363d] bg-[#0d1117]">
          <Breadcrumb />
        </header>

        {/* Page content */}
        <div className="flex-1 overflow-y-auto bg-[#0d1117]">
          <div className="p-6">
            <Outlet />
          </div>
        </div>
      </main>
    </div>
  )
}

function Breadcrumb() {
  const location = useLocation()
  const segments = location.pathname.split('/').filter(Boolean)
  const labels = {
    dashboard: 'Dashboard',
    playlists: 'Playlists',
    discovery: 'Discovery Queue',
    connections: 'Connections',
    settings: 'Settings',
  }

  return (
    <div className="flex items-center gap-1.5 text-sm">
      <span className="text-[#8b949e]" style={{ fontFamily: 'Syne, ui-sans-serif', fontWeight: 600 }}>
        JellyDJ
      </span>
      {segments.map((seg, i) => (
        <span key={seg} className="flex items-center gap-1.5">
          <ChevronRight size={13} className="text-[#30363d]" />
          <span className={i === segments.length - 1 ? 'text-[#e6edf3] font-medium' : 'text-[#8b949e]'}>
            {labels[seg] || seg}
          </span>
        </span>
      ))}
    </div>
  )
}
