import { useState, useEffect } from 'react'
import {
  Clock, RefreshCw, Loader2, Save, Play, Music2,
  Telescope, ToggleLeft, ToggleRight, Zap
} from 'lucide-react'

function SliderRow({ label, value, onChange, min = 1, max = 168, markers, unit = 'h' }) {
  return (
    <div>
      <div className="flex items-center justify-between mb-1.5">
        <span className="text-xs text-[#8b949e]">{label}</span>
        <span className="text-xs font-mono font-semibold text-[#e6edf3]">
          every {value}{unit}
        </span>
      </div>
      <input
        type="range" min={min} max={max} step={1} value={value}
        onChange={e => onChange(Number(e.target.value))}
        className="w-full accent-[#00d4aa]"
      />
      {markers && (
        <div className="flex justify-between text-[10px] text-[#484f58] mt-0.5">
          {markers.map(m => <span key={m}>{m}</span>)}
        </div>
      )}
    </div>
  )
}

function Toggle({ enabled, onChange }) {
  return (
    <button
      onClick={() => onChange(!enabled)}
      className={`flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-semibold
                  transition-all border ${enabled
        ? 'bg-[#00d4aa]/10 border-[#00d4aa]/30 text-[#00d4aa]'
        : 'bg-[#21262d] border-[#30363d] text-[#8b949e]'}`}
    >
      {enabled ? <ToggleRight size={13} /> : <ToggleLeft size={13} />}
      {enabled ? 'On' : 'Off'}
    </button>
  )
}

function TaskCard({ icon: Icon, color, title, description, lastRun, nextRun,
                    enabled, onToggle, triggerLabel, onTrigger, triggering, children }) {
  return (
    <div className="border border-[#30363d] rounded-xl p-4 space-y-3 bg-[#0d1117]">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-2.5">
          <div className="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
               style={{ background: `${color}18`, border: `1px solid ${color}30` }}>
            <Icon size={15} style={{ color }} />
          </div>
          <div>
            <div className="text-sm font-semibold text-[#e6edf3]">{title}</div>
            <div className="text-[11px] text-[#8b949e]">{description}</div>
          </div>
        </div>
        {onToggle && <Toggle enabled={enabled} onChange={onToggle} />}
      </div>

      {children}

      <div className="flex items-center justify-between pt-1">
        <div className="space-y-0.5">
          {lastRun && (
            <div className="text-[10px] text-[#484f58]">
              Last run: {new Date(lastRun + 'Z').toLocaleString()}
            </div>
          )}
          {nextRun && !nextRun.paused && (
            <div className="text-[10px] text-[#484f58]">
              Next: {new Date(nextRun.next_run + 'Z').toLocaleString()}
            </div>
          )}
        </div>
        <button
          onClick={onTrigger}
          disabled={triggering}
          className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                     transition-all disabled:opacity-40"
          style={{
            background: `${color}12`,
            border: `1px solid ${color}25`,
            color,
          }}
        >
          {triggering ? <Loader2 size={11} className="animate-spin" /> : <Zap size={11} />}
          {triggerLabel}
        </button>
      </div>
    </div>
  )
}

export default function AutomationPanel() {
  const [settings, setSettings] = useState(null)
  const [jobStatus, setJobStatus] = useState({})
  const [saving, setSaving] = useState(false)
  const [triggering, setTriggering] = useState({})
  const [msg, setMsg] = useState('')

  // Local editable state
  const [indexHours, setIndexHours] = useState(6)
  const [discoveryEnabled, setDiscoveryEnabled] = useState(true)
  const [discoveryHours, setDiscoveryHours] = useState(24)
  const [discoveryItems, setDiscoveryItems] = useState(10)
  const [playlistEnabled, setPlaylistEnabled] = useState(true)
  const [playlistHours, setPlaylistHours] = useState(24)

  const fetchAll = () => {
    fetch('/api/automation/settings').then(r => r.json()).then(d => {
      setSettings(d)
      setIndexHours(d.index_interval_hours)
      setDiscoveryEnabled(d.discovery_refresh_enabled)
      setDiscoveryHours(d.discovery_refresh_interval_hours)
      setDiscoveryItems(d.discovery_items_per_run)
      setPlaylistEnabled(d.playlist_regen_enabled)
      setPlaylistHours(d.playlist_regen_interval_hours)
    }).catch(() => {})
    fetch('/api/automation/scheduler-status').then(r => r.json()).then(d => {
      setJobStatus(d.jobs || {})
    }).catch(() => {})
  }

  useEffect(() => { fetchAll() }, [])

  const handleSave = async () => {
    setSaving(true)
    try {
      await fetch('/api/automation/settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          index_interval_hours: indexHours,
          discovery_refresh_enabled: discoveryEnabled,
          discovery_refresh_interval_hours: discoveryHours,
          discovery_items_per_run: discoveryItems,
          playlist_regen_enabled: playlistEnabled,
          playlist_regen_interval_hours: playlistHours,
        }),
      })
      setMsg('Saved.')
      setTimeout(() => setMsg(''), 4000)
      fetchAll()
    } finally {
      setSaving(false)
    }
  }

  const trigger = async (key, url) => {
    setTriggering(p => ({ ...p, [key]: true }))
    try {
      const r = await fetch(url, { method: 'POST' })
      const d = await r.json()
      setMsg(d.message || 'Started.')
      setTimeout(() => { setMsg(''); fetchAll() }, 3000)
    } finally {
      setTriggering(p => ({ ...p, [key]: false }))
    }
  }

  return (
    <div className="card space-y-5">
      <div className="flex items-center gap-3">
        <div className="w-9 h-9 rounded-lg bg-[#00d4aa]/10 border border-[#00d4aa]/20
                        flex items-center justify-center flex-shrink-0">
          <Clock size={16} className="text-[#00d4aa]" />
        </div>
        <div>
          <div className="text-sm font-semibold text-[#e6edf3]">Automation</div>
          <div className="text-xs text-[#8b949e]">Scheduled tasks and rate limiting</div>
        </div>
      </div>

      <TaskCard
        icon={RefreshCw} color="#00d4aa" title="Play History & Library Index"
        description="Scans Jellyfin, rebuilds scores for all users"
        lastRun={settings?.last_index}
        nextRun={jobStatus['play_history_index']}
        triggerLabel="Run Now"
        onTrigger={() => trigger('index', '/api/automation/trigger/index')}
        triggering={triggering.index}
      >
        <SliderRow
          label="Run frequency"
          value={indexHours} onChange={setIndexHours}
          min={1} max={48}
          markers={['1h', '6h', '12h', '24h', '48h']}
        />
      </TaskCard>

      <TaskCard
        icon={Telescope} color="#388bfd" title="Discovery Queue Refresh"
        description="Finds new album recommendations and adds them to the queue"
        lastRun={settings?.last_discovery_refresh}
        nextRun={jobStatus['discovery_refresh']}
        enabled={discoveryEnabled} onToggle={setDiscoveryEnabled}
        triggerLabel="Refresh Now"
        onTrigger={() => trigger('discovery', '/api/automation/trigger/discovery')}
        triggering={triggering.discovery}
      >
        <SliderRow
          label="Refresh every"
          value={discoveryHours} onChange={setDiscoveryHours}
          min={6} max={168}
          markers={['6h', '24h', '48h', '1 week']}
        />
        <div>
          <div className="flex items-center justify-between mb-1.5">
            <span className="text-xs text-[#8b949e]">Max new items per run</span>
            <span className="text-xs font-mono font-semibold text-[#e6edf3]">{discoveryItems} items</span>
          </div>
          <input
            type="range" min={1} max={30} step={1} value={discoveryItems}
            onChange={e => setDiscoveryItems(Number(e.target.value))}
            className="w-full accent-[#388bfd]"
          />
          <div className="flex justify-between text-[10px] text-[#484f58] mt-0.5">
            <span>1 (careful)</span><span>10 (default)</span><span>30 (aggressive)</span>
          </div>
          <p className="text-[10px] text-[#484f58] mt-1">
            Limits how many albums get queued per run. Lower = slower library growth,
            less Lidarr load. Higher = more music discovered faster.
          </p>
        </div>
      </TaskCard>

      <TaskCard
        icon={Music2} color="#f78166" title="Playlist Regeneration"
        description="Rewrites For You, Discover Weekly, Most Played, Recently Played in Jellyfin"
        lastRun={settings?.last_playlist_regen}
        nextRun={jobStatus['playlist_regen']}
        enabled={playlistEnabled} onToggle={setPlaylistEnabled}
        triggerLabel="Regen Now"
        onTrigger={() => trigger('playlists', '/api/automation/trigger/playlists')}
        triggering={triggering.playlists}
      >
        <SliderRow
          label="Regenerate every"
          value={playlistHours} onChange={setPlaylistHours}
          min={1} max={168}
          markers={['1h', '12h', '24h', '48h', '1 week']}
        />
      </TaskCard>

      <div className="flex items-center gap-3 pt-1">
        <button
          onClick={handleSave}
          disabled={saving}
          className="flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-semibold
                     bg-[#00d4aa] hover:bg-[#00c49c] text-[#0d1117] disabled:opacity-40 transition-all"
        >
          {saving ? <Loader2 size={12} className="animate-spin" /> : <Save size={12} />}
          Save All Settings
        </button>
        {msg && <span className="text-xs text-[#00d4aa]">{msg}</span>}
      </div>
    </div>
  )
}
</file>

