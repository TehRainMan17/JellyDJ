import { useState, useEffect, useCallback } from 'react'
import { Activity, Music2, ListMusic, Telescope, CheckCircle2, XCircle, Loader2, RefreshCw, Clock, Database, SkipForward, Heart, Disc3 } from 'lucide-react'
import { Link } from 'react-router-dom'

function ConnectionStatusCard({ service, label }) {
  const [data, setData] = useState(null)
  useEffect(() => {
    fetch(`/api/connections/${service}`).then(r => r.json()).then(setData).catch(() => setData({ is_connected: false }))
  }, [service])
  const connected = data?.is_connected
  return (
    <div className="card flex items-center gap-3">
      <div className={`w-2.5 h-2.5 rounded-full flex-shrink-0 transition-all ${
        data === null ? 'bg-[#30363d]' : connected
          ? 'bg-[#00d4aa] shadow-[0_0_8px_rgba(0,212,170,0.5)]'
          : 'bg-[#f85149]'}`}
      />
      <div className="flex-1 min-w-0">
        <div className="text-sm font-medium text-[#e6edf3]">{label}</div>
        {data === null ? <div className="text-xs text-[#8b949e]">Checking…</div>
          : connected ? <div className="text-xs text-[#00d4aa]">Connected</div>
          : <div className="text-xs text-[#8b949e]">Not connected — <Link to="/connections" className="text-[#00d4aa] hover:underline">configure</Link></div>
        }
      </div>
      {data === null ? <Loader2 size={13} className="text-[#8b949e] animate-spin flex-shrink-0" />
        : connected ? <CheckCircle2 size={13} className="text-[#00d4aa] flex-shrink-0" />
        : <XCircle size={13} className="text-[#f85149] flex-shrink-0" />}
    </div>
  )
}

function UserSyncCard({ user }) {
  const statusColor = user.status === 'ok'
    ? 'text-[#00d4aa]'
    : user.status === 'error'
    ? 'text-[#f85149]'
    : 'text-[#8b949e]'
  const statusLabel = user.status === 'ok'
    ? 'Synced'
    : user.status === 'error'
    ? 'Sync error'
    : 'Never synced — run Index Now'
  const avatarBg = user.status === 'never'
    ? 'bg-[#161b22] border-dashed'
    : 'bg-[#21262d]'
  return (
    <div className={`card ${user.status === 'never' ? 'border-dashed border-[#30363d]' : ''}`}>
      <div className="flex items-start justify-between mb-3">
        <div className="flex items-center gap-2.5">
          <div className={`w-8 h-8 rounded-full ${avatarBg} border border-[#30363d]
                          flex items-center justify-center text-xs font-bold text-[#8b949e]`}>
            {user.username[0]?.toUpperCase()}
          </div>
          <div>
            <div className="text-sm font-semibold text-[#e6edf3]">{user.username}</div>
            <div className={`text-xs ${statusColor}`}>{statusLabel}</div>
          </div>
        </div>
      </div>
      <div className="grid grid-cols-2 gap-3">
        <div>
          <div className="text-xs text-[#8b949e] uppercase tracking-wider">Tracks</div>
          <div className="text-xl font-bold text-[#e6edf3] mt-0.5" style={{ fontFamily: 'Syne' }}>
            {user.tracks_indexed > 0 ? user.tracks_indexed.toLocaleString() : '—'}
          </div>
        </div>
        <div>
          <div className="text-xs text-[#8b949e] uppercase tracking-wider">Last sync</div>
          <div className="text-xs text-[#e6edf3] mt-1">
            {user.last_synced ? new Date(user.last_synced + 'Z').toLocaleString() : '—'}
          </div>
        </div>
      </div>
    </div>
  )
}


// ── Activity feed ─────────────────────────────────────────────────────────────

const EVENT_META = {
  index_complete:      { icon: Database,     color: '#00d4aa', label: 'Index complete' },
  index_error:         { icon: XCircle,      color: '#f85149', label: 'Index error' },
  playlist_generated:  { icon: Music2,       color: '#f78166', label: 'Playlists regenerated' },
  discovery_refreshed: { icon: Telescope,    color: '#388bfd', label: 'Discovery refreshed' },
  track_approved:      { icon: CheckCircle2, color: '#00d4aa', label: 'Approved' },
  track_rejected:      { icon: XCircle,      color: '#8b949e', label: 'Rejected' },
  track_snoozed:       { icon: Clock,        color: '#8b949e', label: 'Snoozed' },
  skip_recorded:       { icon: SkipForward,  color: '#e6ab00', label: 'Skip recorded' },
}

function timeAgo(dateStr) {
  const diff = (Date.now() - new Date(dateStr)) / 1000
  if (diff < 60) return 'just now'
  if (diff < 3600) return `${Math.floor(diff / 60)}m ago`
  if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`
  return `${Math.floor(diff / 86400)}d ago`
}

function ActivityFeed({ events }) {
  return (
    <div className="card">
      <div className="flex items-center gap-2 mb-4">
        <Activity size={15} className="text-[#8b949e]" />
        <span className="text-xs font-medium text-[#8b949e] uppercase tracking-wider">Recent Activity</span>
      </div>
      {events.length === 0 ? (
        <div className="text-sm text-[#8b949e] py-4 text-center">
          No activity yet — run an index to get started.
        </div>
      ) : (
        <div className="space-y-0">
          {events.map((e, i) => {
            const meta = EVENT_META[e.event_type] || { icon: Activity, color: '#8b949e', label: e.event_type }
            const Icon = meta.icon
            return (
              <div key={e.id}
                className={`flex items-start gap-3 py-2.5 ${i < events.length - 1 ? 'border-b border-[#21262d]' : ''}`}>
                <div className="w-6 h-6 rounded-md flex items-center justify-center flex-shrink-0 mt-0.5"
                     style={{ background: `${meta.color}15` }}>
                  <Icon size={12} style={{ color: meta.color }} />
                </div>
                <div className="flex-1 min-w-0">
                  <div className="text-xs text-[#e6edf3] truncate">{e.message}</div>
                  <div className="text-[10px] text-[#484f58] mt-0.5">{meta.label}</div>
                </div>
                <div className="text-[10px] text-[#484f58] flex-shrink-0 mt-0.5">
                  {timeAgo(e.created_at)}
                </div>
              </div>
            )
          })}
        </div>
      )}
    </div>
  )
}

export default function Dashboard() {
  const [health, setHealth] = useState(null)
  const [syncStatuses, setSyncStatuses] = useState([])
  const [runningIndex, setRunningIndex] = useState(false)
  const [indexMsg, setIndexMsg] = useState('')
  const [schedulerStatus, setSchedulerStatus] = useState(null)
  const [discoveryCounts, setDiscoveryCounts] = useState(null)
  const [libraryStats, setLibraryStats] = useState(null)
  const [activity, setActivity] = useState([])

  const fetchSyncStatus = useCallback(() => {
    fetch('/api/indexer/status').then(r => r.json()).then(setSyncStatuses).catch(() => {})
    fetch('/api/indexer/scheduler').then(r => r.json()).then(setSchedulerStatus).catch(() => {})
    fetch('/api/discovery/counts').then(r => r.json()).then(setDiscoveryCounts).catch(() => {})
    fetch('/api/indexer/library-stats').then(r => r.json()).then(setLibraryStats).catch(() => {})
    fetch('/api/automation/activity?limit=20').then(r => r.json()).then(setActivity).catch(() => {})
  }, [])

  useEffect(() => {
    fetch('/api/health').then(r => r.json()).then(setHealth).catch(() => setHealth({ status: 'error' }))
    fetchSyncStatus()
  }, [fetchSyncStatus])

  const handleRunNow = async () => {
    setRunningIndex(true)
    setIndexMsg('')
    try {
      const r = await fetch('/api/indexer/run-now', { method: 'POST' })
      const data = await r.json()
      setIndexMsg(data.message || 'Index started.')
      // Poll status after a short delay
      setTimeout(fetchSyncStatus, 3000)
      setTimeout(fetchSyncStatus, 8000)
    } catch {
      setIndexMsg('Failed to trigger index.')
    } finally {
      setRunningIndex(false)
      setTimeout(() => setIndexMsg(''), 6000)
    }
  }

  const totalTracks = syncStatuses.reduce((sum, u) => sum + u.tracks_indexed, 0)
  const nextIndex = schedulerStatus?.play_history_index?.next_run

  return (
    <div className="space-y-6">
      <div>
        <h1 className="text-2xl font-bold text-[#e6edf3]" style={{ fontFamily: 'Syne' }}>Dashboard</h1>
        <p className="text-sm text-[#8b949e] mt-1">System overview and recent activity</p>
      </div>

      {/* Backend health */}
      <div className="card flex items-center gap-3">
        <div className={`w-2.5 h-2.5 rounded-full flex-shrink-0 ${health?.status === 'ok' ? 'bg-[#00d4aa] shadow-[0_0_8px_rgba(0,212,170,0.5)]' : 'bg-[#f85149]'}`} />
        <div className="flex-1">
          <div className="text-sm font-medium text-[#e6edf3]">
            JellyDJ Backend — {health ? (health.status === 'ok' ? 'Running' : 'Error') : 'Checking…'}
          </div>
          {health?.version && <div className="text-xs text-[#8b949e] font-mono mt-0.5">v{health.version}</div>}
        </div>
        {nextIndex && (
          <div className="flex items-center gap-1.5 text-xs text-[#8b949e]">
            <Clock size={11} />
            Next index: {new Date(nextIndex + 'Z').toLocaleTimeString()}
          </div>
        )}
      </div>

      {/* Connection status */}
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <ConnectionStatusCard service="jellyfin" label="Jellyfin" />
        <ConnectionStatusCard service="lidarr" label="Lidarr" />
      </div>

      {/* Stats */}
      <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div className="card">
          <div className="flex items-start justify-between">
            <div>
              <div className="text-xs text-[#8b949e] font-medium uppercase tracking-wider">Tracks Indexed</div>
              <div className="text-3xl font-bold text-[#e6edf3] mt-1" style={{ fontFamily: 'Syne' }}>
                {totalTracks > 0 ? totalTracks.toLocaleString() : '—'}
              </div>
              <div className="text-xs text-[#8b949e] mt-1">
                {syncStatuses.length > 0 ? `Across ${syncStatuses.length} user(s)` : 'No users synced yet'}
              </div>
            </div>
            <Music2 size={18} className="text-[#30363d] mt-0.5" />
          </div>
        </div>
        <div className="card">
          <div className="flex items-start justify-between">
            <div>
              <div className="text-xs text-[#8b949e] font-medium uppercase tracking-wider">Library Tracks</div>
              <div className="text-3xl font-bold text-[#e6edf3] mt-1" style={{ fontFamily: 'Syne' }}>
                {libraryStats ? libraryStats.total_tracks.toLocaleString() : '—'}
              </div>
              <div className="text-xs text-[#8b949e] mt-1">
                {libraryStats ? `${libraryStats.total_artists} artists · ${libraryStats.total_albums} albums` : 'Run a scan to populate'}
              </div>
            </div>
            <ListMusic size={18} className="text-[#30363d] mt-0.5" />
          </div>
        </div>
        <div className="card">
          <div className="flex items-start justify-between">
            <div>
              <div className="text-xs text-[#8b949e] font-medium uppercase tracking-wider">Pending Approvals</div>
              <div className="text-3xl font-bold text-[#e6edf3] mt-1" style={{ fontFamily: 'Syne' }}>
                {discoveryCounts?.pending ?? '—'}
              </div>
              <div className="text-xs text-[#8b949e] mt-1">
                {discoveryCounts
                  ? <Link to="/discovery" className="text-[#00d4aa] hover:underline">View queue →</Link>
                  : 'No queue data yet'}
              </div>
            </div>
            <Telescope size={18} className="text-[#30363d] mt-0.5" />
          </div>
        </div>
      </div>

      {/* Per-user sync cards — always show when any managed users exist */}
      <div>
        <div className="flex items-center justify-between mb-3">
          <h2 className="text-sm font-semibold text-[#8b949e] uppercase tracking-wider">User Sync Status</h2>
          <div className="flex items-center gap-2">
            {indexMsg && <span className="text-xs text-[#00d4aa]">{indexMsg}</span>}
            <button
              onClick={handleRunNow}
              disabled={runningIndex}
              className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         bg-[#21262d] hover:bg-[#2d333b] border border-[#30363d] text-[#e6edf3]
                         disabled:opacity-40 transition-all"
            >
              {runningIndex ? <Loader2 size={12} className="animate-spin" /> : <RefreshCw size={12} />}
              Index Now
            </button>
          </div>
        </div>
        {syncStatuses.length === 0 ? (
          <div className="card flex flex-col items-center justify-center py-10 text-center gap-2">
            <RefreshCw size={24} className="text-[#30363d]" />
            <div className="text-sm text-[#8b949e]">No managed users yet</div>
            <div className="text-xs text-[#8b949e]/60 max-w-xs">
              Enable managed users in <Link to="/connections" className="text-[#00d4aa] hover:underline">Connections</Link>, then run an index to populate data.
            </div>
          </div>
        ) : (
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {syncStatuses.map(u => <UserSyncCard key={u.user_id} user={u} />)}
          </div>
        )}
      </div>

      {/* Activity feed */}
      <ActivityFeed events={activity} />
    </div>
  )
}
