<file path="frontend/src/index.css">
@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --bg:           #0a0e17;
  --bg-surface:   #111827;
  --bg-elevated:  #1a2235;
  --bg-overlay:   #1f2d42;
  --border:       rgba(99, 130, 180, 0.12);
  --border-mid:   rgba(99, 130, 180, 0.22);
  --accent:       #00d4aa;
  --accent-dim:   #00a882;
  --accent-glow:  rgba(0, 212, 170, 0.18);
  --accent-soft:  rgba(0, 212, 170, 0.07);
  --text-primary:   #e8edf5;
  --text-secondary: #8899b5;
  --text-muted:     #4a5568;
  --danger:  #f87171;
  --warning: #fbbf24;
  --purple:  #a78bfa;
  --sidebar-w: 220px;
  --header-h:  56px;
}

@layer base {
  *, *::before, *::after { box-sizing: border-box; }
  html, body, #root { height: 100%; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: 'DM Sans', ui-sans-serif, system-ui;
    -webkit-font-smoothing: antialiased;
  }
  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(99,130,180,0.2); border-radius: 99px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(99,130,180,0.35); }
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 4px; }
  ::selection { background: var(--accent-glow); color: var(--text-primary); }
}

@layer components {
  .nav-item {
    @apply flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium
           transition-all duration-150 cursor-pointer select-none relative;
    color: var(--text-secondary);
  }
  .nav-item:hover { color: var(--text-primary); background: rgba(255,255,255,0.04); }
  .nav-item.active { color: var(--accent); background: var(--accent-soft); }
  .nav-item.active::before {
    content: ''; position: absolute; left: 0; top: 20%; bottom: 20%;
    width: 3px; background: var(--accent); border-radius: 0 2px 2px 0;
  }

  .card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
    transition: border-color 150ms ease;
  }
  .card:hover { border-color: var(--border-mid); }

  .badge {
    @apply inline-flex items-center justify-center min-w-[18px] h-[18px]
           px-1.5 rounded-full text-[10px] font-bold font-mono;
    background: var(--accent); color: #0a0e17;
  }

  .btn {
    @apply inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl
           text-sm font-semibold transition-all duration-150
           disabled:opacity-40 disabled:cursor-not-allowed;
  }
  .btn-primary {
    @apply btn;
    background: var(--accent); color: #0a0e17;
  }
  .btn-primary:hover:not(:disabled) {
    background: var(--accent-dim);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--accent-glow);
  }
  .btn-primary:active:not(:disabled) { transform: none; box-shadow: none; }

  .btn-secondary {
    @apply btn;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    color: var(--text-secondary);
  }
  .btn-secondary:hover:not(:disabled) {
    background: rgba(255,255,255,0.08);
    color: var(--text-primary);
    border-color: var(--border-mid);
  }

  .input {
    @apply w-full rounded-xl px-3 py-2 text-sm transition-all;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    color: var(--text-primary);
  }
  .input::placeholder { color: var(--text-muted); }
  .input:focus {
    outline: none;
    border-color: rgba(0,212,170,0.5);
    box-shadow: 0 0 0 3px rgba(0,212,170,0.08);
    background: rgba(255,255,255,0.06);
  }

  .tab-bar { @apply flex gap-1 p-1 rounded-xl; background: rgba(0,0,0,0.25); border: 1px solid var(--border); }
  .tab { @apply flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold transition-all; color: var(--text-secondary); }
  .tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.04); }
  .tab.active { background: var(--bg-elevated); color: var(--text-primary); box-shadow: 0 1px 4px rgba(0,0,0,0.4); }

  .section-label { @apply text-[10px] font-semibold uppercase tracking-widest; color: var(--text-muted); }
  .stat-val { font-family: 'Syne', ui-sans-serif; font-weight: 700; color: var(--text-primary); line-height: 1; }
}

@layer utilities {
  @keyframes fade-up   { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
  @keyframes fade-in   { from { opacity:0; } to { opacity:1; } }
  @keyframes slide-r   { from { transform:translateX(100%); } to { transform:none; } }
  @keyframes scale-in  { from { opacity:0; transform:scale(0.95); } to { opacity:1; transform:none; } }
  @keyframes shimmer   { from { background-position:-200% 0; } to { background-position:200% 0; } }
  @keyframes glow-pulse {
    0%,100% { box-shadow: 0 0 6px rgba(0,212,170,0.3); }
    50%      { box-shadow: 0 0 18px rgba(0,212,170,0.6); }
  }

  .anim-fade-up  { animation: fade-up  0.35s ease both; }
  .anim-fade-in  { animation: fade-in  0.25s ease both; }
  .anim-slide-r  { animation: slide-r  0.3s cubic-bezier(0.4,0,0.2,1) both; }
  .anim-scale-in { animation: scale-in 0.25s ease both; }
  .anim-glow     { animation: glow-pulse 2s ease-in-out infinite; }

  .stagger > *:nth-child(1) { animation-delay:0ms; }
  .stagger > *:nth-child(2) { animation-delay:50ms; }
  .stagger > *:nth-child(3) { animation-delay:100ms; }
  .stagger > *:nth-child(4) { animation-delay:150ms; }
  .stagger > *:nth-child(5) { animation-delay:200ms; }
  .stagger > *:nth-child(6) { animation-delay:250ms; }
  .stagger > *:nth-child(7) { animation-delay:300ms; }
  .stagger > *:nth-child(8) { animation-delay:350ms; }

  .skeleton {
    background: linear-gradient(90deg, var(--bg-elevated) 25%, var(--bg-overlay) 50%, var(--bg-elevated) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.6s infinite;
    border-radius: 8px;
  }

  .page-enter { animation: fade-up 0.3s ease both; }
  .text-accent { color: var(--accent); }
  .text-accent-glow { color: var(--accent); text-shadow: 0 0 20px var(--accent-glow); }
}

/* Range inputs */
input[type=range] { -webkit-appearance:none; appearance:none; height:4px; border-radius:99px; background:var(--bg-overlay); cursor:pointer; width:100%; }
input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; width:16px; height:16px; border-radius:50%; background:var(--accent); border:2px solid var(--bg); box-shadow:0 0 8px var(--accent-glow); transition:transform 150ms,box-shadow 150ms; }
input[type=range]::-webkit-slider-thumb:hover { transform:scale(1.2); box-shadow:0 0 14px rgba(0,212,170,0.55); }
input[type=range]::-moz-range-thumb { width:16px; height:16px; border-radius:50%; background:var(--accent); border:2px solid var(--bg); }

/* Indeterminate progress bar (used while waiting for sync endpoints) */
@keyframes indeterminate {
  0%   { transform: translateX(-100%) scaleX(0.5); }
  50%  { transform: translateX(0%)    scaleX(0.6); }
  100% { transform: translateX(200%)  scaleX(0.5); }
}
.anim-progress-bar { animation: indeterminate 1.5s ease-in-out infinite; }

/* Pulsing dot */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.3; }
}

/* Mobile */
@media (max-width:1023px) { .card { padding:1rem; } }
