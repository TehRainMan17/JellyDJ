              className="px-3 py-1 text-xs bg-[var(--bg-overlay)] border border-[var(--border)] rounded-lg
                         text-[var(--text-secondary)] hover:text-[var(--text-primary)] disabled:opacity-40 transition-colors">
              Next →
            </button>
          </div>
        )}
      </div>
    </div>
  )
}

