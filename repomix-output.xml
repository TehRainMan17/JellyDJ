import { useState, useEffect } from 'react'
import { Zap, Copy, CheckCircle2, ChevronDown, ChevronUp, ExternalLink } from 'lucide-react'

export default function WebhookSetupPanel() {
  const [guide, setGuide] = useState(null)
  const [open, setOpen] = useState(false)
  const [copied, setCopied] = useState(false)

  useEffect(() => {
    fetch('/api/webhooks/setup-guide')
      .then(r => r.json())
      .then(setGuide)
      .catch(() => {})
  }, [])

  const handleCopy = () => {
    if (!guide?.webhook_url) return
    navigator.clipboard.writeText(guide.webhook_url)
    setCopied(true)
    setTimeout(() => setCopied(false), 2000)
  }

  return (
    <div className="card space-y-4">
      <div className="flex items-start justify-between">
        <div className="flex items-center gap-3">
          <div className="w-9 h-9 rounded-lg bg-[#e3b341]/10 border border-[#e3b341]/20 flex items-center justify-center flex-shrink-0">
            <Zap size={16} className="text-[#e3b341]" />
          </div>
          <div>
            <div className="text-sm font-semibold text-[#e6edf3]">Playback Webhooks</div>
            <div className="text-xs text-[#8b949e] mt-0.5">
              Skip tracking via Jellyfin playback events
            </div>
          </div>
        </div>
        <button
          onClick={() => setOpen(v => !v)}
          className="flex items-center gap-1.5 text-xs text-[#8b949e] hover:text-[#e6edf3] transition-colors"
        >
          Setup guide
          {open ? <ChevronUp size={13} /> : <ChevronDown size={13} />}
        </button>
      </div>

      <p className="text-xs text-[#8b949e]">
        When configured, JellyDJ tracks how much of each song you listen to.
        Tracks skipped before <strong className="text-[#e6edf3]">{guide?.skip_threshold || '80%'}</strong> completion
        accumulate a skip penalty that reduces their playlist score over time.
        Artist and genre affinity scores are also dampened for frequently skipped content.
      </p>

      {open && guide && (
        <div className="space-y-4 pt-1">
          {/* Webhook URL */}
          <div>
            <div className="text-xs font-medium text-[#8b949e] uppercase tracking-wider mb-2">
              Webhook URL
            </div>
            <div className="flex items-center gap-2">
              <code className="flex-1 bg-[#0d1117] border border-[#30363d] rounded-lg px-3 py-2
                              text-xs text-[#00d4aa] font-mono overflow-x-auto whitespace-nowrap">
                {guide.webhook_url}
              </code>
              <button
                onClick={handleCopy}
                className="flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold
                           bg-[#21262d] hover:bg-[#2d333b] border border-[#30363d] text-[#e6edf3]
                           transition-all flex-shrink-0"
              >
                {copied
                  ? <><CheckCircle2 size={12} className="text-[#00d4aa]" /> Copied</>
                  : <><Copy size={12} /> Copy</>
                }
              </button>
            </div>
          </div>

          {/* Step-by-step */}
          <div>
            <div className="text-xs font-medium text-[#8b949e] uppercase tracking-wider mb-2">
              Jellyfin Setup Steps
            </div>
            <ol className="space-y-2">
              {guide.instructions.map((step, i) => (
                <li key={i} className="flex gap-3 text-xs text-[#8b949e]">
                  <span className="flex-shrink-0 w-5 h-5 rounded-full bg-[#21262d] border border-[#30363d]
                                   flex items-center justify-center text-[10px] font-mono text-[#e6edf3]">
                    {i + 1}
                  </span>
                  <span className="pt-0.5">{step.replace(/^\d+\.\s*/, '')}</span>
                </li>
              ))}
            </ol>
          </div>

          <div className="flex items-start gap-2 bg-[#e3b341]/5 border border-[#e3b341]/20 rounded-lg px-3 py-2.5">
            <Zap size={13} className="text-[#e3b341] flex-shrink-0 mt-0.5" />
            <p className="text-xs text-[#8b949e]">
              After setup, verify it's working at{' '}
              <code className="text-[#e6edf3] font-mono">/api/webhooks/recent/YOUR_USER_ID</code>
              {' '}— play and skip a song in Jellyfin, then refresh.
            </p>
          </div>
        </div>
      )}
    </div>
  )
}
