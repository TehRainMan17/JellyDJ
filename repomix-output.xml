<file path="frontend/src/pages/DiscoveryQueue.jsx">
import { useState, useEffect, useCallback } from 'react'
import {
  Telescope, RefreshCw, Check, X, Clock, Send,
  Loader2, Music2, ChevronDown, ChevronUp, Filter, Trash2
} from 'lucide-react'

// ── Status config ─────────────────────────────────────────────────────────────

const STATUS_TABS = [
  { key: 'pending',  label: 'Pending',  color: '#e3b341' },
  { key: 'approved', label: 'Approved', color: '#00d4aa' },
  { key: 'rejected', label: 'Rejected', color: '#f85149' },
  { key: 'snoozed',  label: 'Snoozed',  color: '#8b949e' },
]

// ── Helpers ───────────────────────────────────────────────────────────────────

function ScoreBadge({ score }) {
  const color = score >= 70 ? '#00d4aa' : score >= 45 ? '#e3b341' : '#8b949e'
  return (
    <div
      className="flex items-center justify-center w-10 h-10 rounded-lg text-xs font-bold flex-shrink-0"
      style={{ background: `${color}15`, border: `1px solid ${color}30`, color }}
    >
      {Math.round(score)}
    </div>
  )
}

function StatusBadge({ status, lidarrSent }) {
  const cfg = {
    pending:  { color: '#e3b341', label: 'Pending' },
    approved: { color: '#00d4aa', label: lidarrSent ? 'Sent ✓' : 'Approved' },
    rejected: { color: '#f85149', label: 'Rejected' },
    snoozed:  { color: '#8b949e', label: 'Snoozed' },
  }[status] || { color: '#8b949e', label: status }

  return (
    <span
      className="text-[10px] font-semibold px-2 py-0.5 rounded-full"
      style={{ background: `${cfg.color}15`, color: cfg.color, border: `1px solid ${cfg.color}30` }}
    >
      {cfg.label}
    </span>
  )
}

// ── Queue item card ───────────────────────────────────────────────────────────

function QueueCard({ item, onAction, onSendToLidarr, onDelete, activeTab }) {
  const [expanded, setExpanded] = useState(false)
  const [actioning, setActioning] = useState(null)
  const [sending, setSending] = useState(false)
  const [msg, setMsg] = useState('')

  const handleAction = async (status) => {
    setActioning(status)
    try {
      await fetch(`/api/discovery/${item.id}/action`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      })
      onAction(item.id, status)
    } finally {
      setActioning(null)
    }
  }

  const handleSend = async () => {
    setSending(true)
    setMsg('')
    try {
      const r = await fetch(`/api/discovery/${item.id}/send-to-lidarr`, { method: 'POST' })
      const data = await r.json()
      if (r.ok) {
        setMsg(data.message)
        onSendToLidarr(item.id)
      } else {
        setMsg(data.detail || 'Failed to send to Lidarr')
      }
    } catch {
      setMsg('Network error')
    } finally {
      setSending(false)
    }
  }

  const handleDelete = async () => {
    await fetch(`/api/discovery/${item.id}`, { method: 'DELETE' })
    onDelete(item.id)
  }

  return (
    <div className="card space-y-3">
      <div className="flex items-start gap-3">
        {/* Score / image */}
        {item.image_url
          ? <img src={item.image_url} alt={item.artist_name}
              className="w-10 h-10 rounded-lg object-cover flex-shrink-0 border border-[#30363d]" />
          : <ScoreBadge score={item.popularity_score} />
        }

        {/* Main info */}
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-2 flex-wrap">
            <span className="text-sm font-semibold text-[#e6edf3] truncate">{item.artist_name}</span>
            <StatusBadge status={item.status} lidarrSent={item.lidarr_sent} />
          </div>
          <div className="text-xs text-[#8b949e] mt-0.5 truncate">
            Similar to <span className="text-[#e6edf3]">{item.source_artist}</span>
            {item.username && <span> · For {item.username}</span>}
          </div>
        </div>

        {/* Score (no image case shows here) */}
        {item.image_url && (
          <div className="text-right flex-shrink-0">
            <div className="text-xs text-[#8b949e]">Score</div>
            <div className="text-sm font-bold text-[#e6edf3]">{Math.round(item.popularity_score)}</div>
          </div>
        )}

        {/* Expand */}
        <button
          onClick={() => setExpanded(v => !v)}
          className="text-[#8b949e] hover:text-[#e6edf3] transition-colors flex-shrink-0"
        >
          {expanded ? <ChevronUp size={14} /> : <ChevronDown size={14} />}
        </button>
      </div>

      {/* Expanded details */}
      {expanded && (
        <div className="border-t border-[#21262d] pt-3 space-y-2">
          <p className="text-xs text-[#8b949e] leading-relaxed">{item.why}</p>
          <div className="flex gap-4 text-xs">
            <div>
              <span className="text-[#8b949e]">Source affinity: </span>
              <span className="text-[#e6edf3] font-mono">{item.source_affinity.toFixed(1)}</span>
            </div>
            {item.release_year && (
              <div>
                <span className="text-[#8b949e]">Year: </span>
                <span className="text-[#e6edf3]">{item.release_year}</span>
              </div>
            )}
            <div>
              <span className="text-[#8b949e]">Added: </span>
              <span className="text-[#e6edf3]">{new Date(item.added_at + 'Z').toLocaleDateString()}</span>
            </div>
          </div>
          {item.lidarr_response && (
            <div className="text-xs text-[#8b949e] font-mono bg-[#0d1117] rounded px-2 py-1.5">
              Lidarr: {item.lidarr_response}
            </div>
          )}
          {msg && (
            <div className="text-xs text-[#00d4aa] bg-[#00d4aa]/5 border border-[#00d4aa]/20 rounded px-2 py-1.5">
              {msg}
            </div>
          )}
        </div>
      )}

      {/* Actions */}
      <div className="flex items-center gap-2 flex-wrap">
        {activeTab === 'pending' && (
          <>
            <button
              onClick={() => handleAction('approved')}
              disabled={!!actioning}
              className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         bg-[#00d4aa]/10 hover:bg-[#00d4aa]/20 border border-[#00d4aa]/30 text-[#00d4aa]
                         disabled:opacity-40 transition-all"
            >
              {actioning === 'approved' ? <Loader2 size={11} className="animate-spin" /> : <Check size={11} />}
              Approve
            </button>
            <button
              onClick={() => handleAction('snoozed')}
              disabled={!!actioning}
              className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         bg-[#8b949e]/10 hover:bg-[#8b949e]/20 border border-[#8b949e]/30 text-[#8b949e]
                         disabled:opacity-40 transition-all"
            >
              {actioning === 'snoozed' ? <Loader2 size={11} className="animate-spin" /> : <Clock size={11} />}
              Snooze
            </button>
            <button
              onClick={() => handleAction('rejected')}
              disabled={!!actioning}
              className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         bg-[#f85149]/10 hover:bg-[#f85149]/20 border border-[#f85149]/30 text-[#f85149]
                         disabled:opacity-40 transition-all"
            >
              {actioning === 'rejected' ? <Loader2 size={11} className="animate-spin" /> : <X size={11} />}
              Reject
            </button>
          </>
        )}

        {activeTab === 'approved' && !item.lidarr_sent && (
          <button
            onClick={handleSend}
            disabled={sending}
            className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                       bg-[#00d4aa]/10 hover:bg-[#00d4aa]/20 border border-[#00d4aa]/30 text-[#00d4aa]
                       disabled:opacity-40 transition-all"
          >
            {sending ? <Loader2 size={11} className="animate-spin" /> : <Send size={11} />}
            Send to Lidarr
          </button>
        )}

        {activeTab === 'approved' && item.lidarr_sent && (
          <span className="text-xs text-[#00d4aa] flex items-center gap-1">
            <Check size={11} /> Sent to Lidarr
          </span>
        )}

        {(activeTab === 'rejected' || activeTab === 'snoozed') && (
          <>
            <button
              onClick={() => handleAction('pending')}
              disabled={!!actioning}
              className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         bg-[#21262d] hover:bg-[#2d333b] border border-[#30363d] text-[#e6edf3]
                         disabled:opacity-40 transition-all"
            >
              {actioning === 'pending' ? <Loader2 size={11} className="animate-spin" /> : <RefreshCw size={11} />}
              Restore
            </button>
            <button
              onClick={handleDelete}
              className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold
                         bg-[#f85149]/10 hover:bg-[#f85149]/20 border border-[#f85149]/30 text-[#f85149]
                         transition-all"
            >
              <Trash2 size={11} /> Delete
            </button>
          </>
        )}
      </div>
    </div>
  )
}

// ── Page root ─────────────────────────────────────────────────────────────────

export default function DiscoveryQueue() {
  const [items, setItems] = useState([])
  const [counts, setCounts] = useState({})
  const [activeTab, setActiveTab] = useState('pending')
  const [loading, setLoading] = useState(false)
  const [populating, setPopulating] = useState(false)
  const [popMsg, setPopMsg] = useState('')

  const fetchItems = useCallback((tab = activeTab) => {
    setLoading(true)
    fetch(`/api/discovery?status=${tab}`)
      .then(r => r.json())
      .then(data => { setItems(data); setLoading(false) })
      .catch(() => setLoading(false))
  }, [activeTab])

  const fetchCounts = useCallback(() => {
    fetch('/api/discovery/counts')
      .then(r => r.json())
      .then(setCounts)
      .catch(() => {})
  }, [])

  useEffect(() => {
    fetchItems(activeTab)
    fetchCounts()
  }, [activeTab, fetchCounts])

  const handleTabChange = (tab) => {
    setActiveTab(tab)
    fetchItems(tab)
  }

  const handlePopulate = async () => {
    setPopulating(true)
    setPopMsg('')
    try {
      const r = await fetch('/api/discovery/populate', { method: 'POST' })
      const data = await r.json()
      setPopMsg(data.ok ? `Added ${data.added} new recommendation${data.added !== 1 ? 's' : ''}.` : 'Populate failed.')
      fetchItems(activeTab)
      fetchCounts()
    } catch {
      setPopMsg('Network error.')
    } finally {
      setPopulating(false)
      setTimeout(() => setPopMsg(''), 6000)
    }
  }

  const handleAction = (id, newStatus) => {
    setItems(prev => prev.filter(i => i.id !== id))
    fetchCounts()
  }

  const handleSendToLidarr = (id) => {
    setItems(prev => prev.map(i => i.id === id ? { ...i, lidarr_sent: true } : i))
  }

  const handleDelete = (id) => {
    setItems(prev => prev.filter(i => i.id !== id))
    fetchCounts()
  }

  return (
    <div className="space-y-6 max-w-2xl">
      {/* Header */}
      <div className="flex items-start justify-between gap-4">
        <div>
          <h1 className="text-2xl font-bold text-[#e6edf3]" style={{ fontFamily: 'Syne' }}>
            Discovery Queue
          </h1>
          <p className="text-sm text-[#8b949e] mt-1">
            Recommended artists — approve to send to Lidarr for download
          </p>
        </div>
        <div className="flex items-center gap-2 flex-shrink-0">
          {popMsg && <span className="text-xs text-[#00d4aa]">{popMsg}</span>}
          <button
            onClick={handlePopulate}
            disabled={populating}
            className="flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold
                       bg-[#00d4aa] hover:bg-[#00c49c] text-[#0d1117] disabled:opacity-40 transition-all"
          >
            {populating ? <Loader2 size={12} className="animate-spin" /> : <Telescope size={12} />}
            Refresh Recs
          </button>
        </div>
      </div>

      {/* Tabs */}
      <div className="flex gap-1 bg-[#161b22] rounded-lg p-1 border border-[#30363d]">
        {STATUS_TABS.map(tab => (
          <button
            key={tab.key}
            onClick={() => handleTabChange(tab.key)}
            className={`flex-1 flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-semibold transition-all ${
              activeTab === tab.key
                ? 'bg-[#21262d] text-[#e6edf3] shadow-sm'
                : 'text-[#8b949e] hover:text-[#e6edf3]'
            }`}
          >
            {tab.label}
            {counts[tab.key] > 0 && (
              <span
                className="text-[10px] font-bold px-1.5 py-0.5 rounded-full min-w-[18px] text-center"
                style={{
                  background: activeTab === tab.key ? `${tab.color}20` : '#21262d',
                  color: activeTab === tab.key ? tab.color : '#8b949e',
                }}
              >
                {counts[tab.key]}
              </span>
            )}
          </button>
        ))}
      </div>

      {/* Item list */}
      {loading ? (
        <div className="flex items-center justify-center py-16">
          <Loader2 size={24} className="animate-spin text-[#30363d]" />
        </div>
      ) : items.length === 0 ? (
        <div className="card flex flex-col items-center justify-center py-16 text-center gap-3">
          <Telescope size={28} className="text-[#30363d]" />
          <div className="text-sm text-[#8b949e]">
            {activeTab === 'pending' ? 'No pending recommendations' : `No ${activeTab} items`}
          </div>
          {activeTab === 'pending' && (
            <div className="text-xs text-[#8b949e]/60 max-w-xs">
              Click "Refresh Recs" to generate recommendations from your play history.
              Make sure the indexer has run and Last.fm is configured.
            </div>
          )}
        </div>
      ) : (
        <div className="space-y-3">
          {items.map(item => (
            <QueueCard
              key={item.id}
              item={item}
              activeTab={activeTab}
              onAction={handleAction}
              onSendToLidarr={handleSendToLidarr}
              onDelete={handleDelete}
            />
          ))}
        </div>
      )}
    </div>
  )
}
