import { useState, useEffect, useCallback } from 'react'
import {
  ListMusic, RefreshCw, CheckCircle2, XCircle,
  Loader2, Clock, ChevronDown, ChevronUp,
  Sparkles, TrendingUp, History, Radio
} from 'lucide-react'

const TYPE_CONFIG = {
  for_you:          { label: 'For You',         icon: Sparkles,   color: '#00d4aa', desc: 'Affinity-weighted picks based on your listening history' },
  discover:         { label: 'Discover Weekly', icon: Radio,      color: '#e3b341', desc: "Novelty-heavy — tracks you haven't heard yet" },
  most_played:      { label: 'Most Played',     icon: TrendingUp, color: '#f78166', desc: 'Your all-time most played tracks' },
  recently_played:  { label: 'Recently Played', icon: History,    color: '#8b949e', desc: "What you've been listening to lately" },
}

function UserCard({ username, playlists }) {
  const [open, setOpen] = useState(true)
  const initial = username?.[0]?.toUpperCase() || '?'
  return (
    <div className="card space-y-3">
      <button onClick={() => setOpen(v => !v)} className="w-full flex items-center gap-3">
        <div className="w-8 h-8 rounded-full bg-[#00d4aa]/10 border border-[#00d4aa]/20
                        flex items-center justify-center text-sm font-bold text-[#00d4aa] flex-shrink-0">
          {initial}
        </div>
        <div className="flex-1 text-left">
          <div className="text-sm font-semibold text-[#e6edf3]">{username}</div>
          <div className="text-xs text-[#8b949e]">{playlists.length} playlist{playlists.length !== 1 ? 's' : ''}</div>
        </div>
        {open ? <ChevronUp size={14} className="text-[#8b949e]" /> : <ChevronDown size={14} className="text-[#8b949e]" />}
      </button>
      {open && (
        <div className="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-1">
          {playlists.map(p => {
            const cfg = TYPE_CONFIG[p.playlist_type] || { label: p.label, color: '#8b949e', icon: ListMusic }
            const Icon = cfg.icon
            return (
              <div key={p.playlist_type}
                className="flex items-center gap-3 bg-[#0d1117] rounded-lg px-3 py-2.5 border border-[#21262d] hover:border-[#30363d] transition-colors">
                <div className="w-7 h-7 rounded-md flex items-center justify-center flex-shrink-0"
                  style={{ background: `${cfg.color}15`, border: `1px solid ${cfg.color}25` }}>
                  <Icon size={13} style={{ color: cfg.color }} />
                </div>
                <div className="flex-1 min-w-0">
                  <div className="text-xs font-medium text-[#e6edf3] truncate">{p.playlist_name}</div>
                  <div className="text-[10px] text-[#8b949e] mt-0.5">{p.tracks_added} tracks · {p.action}</div>
                </div>
              </div>
            )
          })}
        </div>
      )}
    </div>
  )
}

function RunHistoryRow({ run, onExpand, expanded }) {
  const duration = run.duration_secs != null
    ? run.duration_secs < 60 ? `${run.duration_secs}s` : `${Math.round(run.duration_secs / 60)}m`
    : '—'
  const statusColor = run.status === 'ok' ? '#00d4aa' : run.status === 'running' ? '#e3b341' : '#f85149'
  return (
    <div className="border border-[#21262d] rounded-lg overflow-hidden">
      <button onClick={() => onExpand(run.id)}
        className="w-full flex items-center gap-3 px-4 py-3 bg-[#161b22] hover:bg-[#1c2128] transition-colors text-left">
        <span className="w-1.5 h-1.5 rounded-full flex-shrink-0" style={{ background: statusColor }} />
        <span className="text-xs text-[#e6edf3] flex-1">
          {new Date((run.finished_at || run.started_at) + 'Z').toLocaleString()}
        </span>
        <span className="text-xs text-[#8b949e]">{run.playlists_written} playlists</span>
        <span className="text-xs text-[#8b949e]">{duration}</span>
        {expanded ? <ChevronUp size={12} className="text-[#8b949e]" /> : <ChevronDown size={12} className="text-[#8b949e]" />}
      </button>
      {expanded && run.items && (
        <div className="px-4 py-3 border-t border-[#21262d] space-y-1.5 bg-[#0d1117]">
          {run.items.map((item, i) => (
            <div key={i} className="flex items-center gap-2 text-xs">
              {item.status === 'ok'
                ? <CheckCircle2 size={11} className="text-[#00d4aa] flex-shrink-0" />
                : <XCircle size={11} className="text-[#f85149] flex-shrink-0" />}
              <span className="text-[#8b949e] flex-1 truncate">{item.playlist_name}</span>
              {item.status === 'ok'
                ? <span className="text-[#8b949e] font-mono">{item.tracks_added}t</span>
                : <span className="text-[#f85149]">{item.status}</span>}
            </div>
          ))}
        </div>
      )}
    </div>
  )
}

export default function Playlists() {
  const [current, setCurrent] = useState(null)
  const [runs, setRuns] = useState([])
  const [users, setUsers] = useState([])
  const [generating, setGenerating] = useState(false)
  const [genMsg, setGenMsg] = useState(null)
  const [expandedRun, setExpandedRun] = useState(null)
  const [runDetails, setRunDetails] = useState({})
  const [selectedTypes, setSelectedTypes] = useState(Object.keys(TYPE_CONFIG))
  const [tab, setTab] = useState('playlists')

  const fetchAll = useCallback(() => {
    fetch('/api/playlists/current').then(r => r.json()).then(setCurrent).catch(() => {})
    fetch('/api/playlists/runs').then(r => r.json()).then(setRuns).catch(() => {})
    fetch('/api/playlists/users').then(r => r.json()).then(setUsers).catch(() => {})
  }, [])

  useEffect(() => { fetchAll() }, [fetchAll])

  const handleGenerate = async () => {
    setGenerating(true)
    setGenMsg(null)
    try {
      const r = await fetch('/api/playlists/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ playlist_types: selectedTypes }),
      })
      const data = await r.json()
      if (r.ok && data.ok) {
        setGenMsg({ text: `✓ ${data.playlists_written} playlist${data.playlists_written !== 1 ? 's' : ''} written to Jellyfin`, ok: true })
        fetchAll()
        setTab('playlists')
      } else {
        setGenMsg({ text: data.error || data.detail || 'Generation failed', ok: false })
      }
    } catch {
      setGenMsg({ text: 'Network error', ok: false })
    } finally {
      setGenerating(false)
      setTimeout(() => setGenMsg(null), 10000)
    }
  }

  const handleExpandRun = async (runId) => {
    if (expandedRun === runId) { setExpandedRun(null); return }
    setExpandedRun(runId)
    if (!runDetails[runId]) {
      const r = await fetch(`/api/playlists/runs/${runId}`)
      const data = await r.json()
      setRunDetails(prev => ({ ...prev, [runId]: data }))
    }
  }

  const toggleType = (t) =>
    setSelectedTypes(prev => prev.includes(t) ? prev.filter(x => x !== t) : [...prev, t])

  const byUser = {}
  if (current?.playlists) {
    for (const p of current.playlists) {
      if (!byUser[p.username]) byUser[p.username] = []
      byUser[p.username].push(p)
    }
  }

  const readyUsers = users.filter(u => u.ready)
  const notReadyUsers = users.filter(u => !u.ready)

  return (
    <div className="space-y-6 max-w-2xl">
      {/* Header */}
      <div className="flex items-start justify-between gap-4">
        <div>
          <h1 className="text-2xl font-bold text-[#e6edf3]" style={{ fontFamily: 'Syne' }}>Playlists</h1>
          <p className="text-sm text-[#8b949e] mt-1">Auto-generated playlists written to Jellyfin for each user</p>
        </div>
        {current?.last_run && (
          <div className="text-right flex-shrink-0">
            <div className="text-[10px] text-[#8b949e]">Last generated</div>
            <div className="text-xs text-[#e6edf3]">{new Date(current.last_run.finished_at + 'Z').toLocaleString()}</div>
          </div>
        )}
      </div>

      {/* Generate panel */}
      <div className="card space-y-4">
        <div className="flex items-center gap-2">
          <ListMusic size={15} className="text-[#00d4aa]" />
          <span className="text-sm font-semibold text-[#e6edf3]">Generate Playlists</span>
        </div>
        <div>
          <div className="text-xs text-[#8b949e] mb-2">Select playlist types</div>
          <div className="flex flex-wrap gap-2">
            {Object.entries(TYPE_CONFIG).map(([type, cfg]) => {
              const Icon = cfg.icon
              const selected = selectedTypes.includes(type)
              return (
                <button key={type} onClick={() => toggleType(type)}
                  className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold transition-all border"
                  style={{
                    background: selected ? `${cfg.color}15` : 'transparent',
                    borderColor: selected ? `${cfg.color}40` : '#30363d',
                    color: selected ? cfg.color : '#8b949e',
                  }}>
                  <Icon size={11} />{cfg.label}
                </button>
              )
            })}
          </div>
        </div>

        {users.length > 0 && (
          <div className="flex flex-wrap gap-2">
            {readyUsers.map(u => (
              <span key={u.jellyfin_user_id}
                className="flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-[#00d4aa]/10 border border-[#00d4aa]/20 text-[#00d4aa]">
                <CheckCircle2 size={10} />{u.username} ({u.tracks_indexed} tracks)
              </span>
            ))}
            {notReadyUsers.map(u => (
              <span key={u.jellyfin_user_id}
                className="flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-[#f85149]/10 border border-[#f85149]/20 text-[#f85149]">
                <XCircle size={10} />{u.username} (not indexed)
              </span>
            ))}
          </div>
        )}

        <div className="flex items-center gap-3 flex-wrap">
          <button onClick={handleGenerate}
            disabled={generating || selectedTypes.length === 0 || readyUsers.length === 0}
            className="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold
                       bg-[#00d4aa] hover:bg-[#00c49c] text-[#0d1117]
                       disabled:opacity-40 disabled:cursor-not-allowed transition-all">
            {generating
              ? <><Loader2 size={14} className="animate-spin" />Generating…</>
              : <><RefreshCw size={14} />Generate Now</>}
          </button>
          {genMsg && <span className={`text-xs ${genMsg.ok ? 'text-[#00d4aa]' : 'text-[#f85149]'}`}>{genMsg.text}</span>}
        </div>

        {generating && (
          <div className="flex items-center gap-2 text-xs text-[#8b949e] bg-[#0d1117] rounded-lg px-3 py-2">
            <Loader2 size={12} className="animate-spin text-[#00d4aa]" />
            Writing playlists to Jellyfin… this may take 15–30 seconds
          </div>
        )}
      </div>

      {/* Tabs */}
      <div className="flex gap-1 bg-[#161b22] rounded-lg p-1 border border-[#30363d]">
        {[
          { key: 'playlists', label: 'Current Playlists', icon: ListMusic },
          { key: 'history',   label: 'Run History',       icon: Clock },
        ].map(t => {
          const Icon = t.icon
          return (
            <button key={t.key} onClick={() => setTab(t.key)}
              className={`flex-1 flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-semibold transition-all ${
                tab === t.key ? 'bg-[#21262d] text-[#e6edf3] shadow-sm' : 'text-[#8b949e] hover:text-[#e6edf3]'}`}>
              <Icon size={12} />{t.label}
            </button>
          )
        })}
      </div>

      {tab === 'playlists' && (
        <div className="space-y-3">
          {Object.keys(byUser).length === 0 ? (
            <div className="card flex flex-col items-center justify-center py-16 text-center gap-3">
              <ListMusic size={28} className="text-[#30363d]" />
              <div className="text-sm text-[#8b949e]">No playlists generated yet</div>
              <div className="text-xs text-[#8b949e]/60 max-w-xs">
                Click "Generate Now" above to create playlists in Jellyfin for all indexed users.
              </div>
            </div>
          ) : Object.entries(byUser).map(([username, playlists]) => (
            <UserCard key={username} username={username} playlists={playlists} />
          ))}
        </div>
      )}

      {tab === 'history' && (
        <div className="space-y-2">
          {runs.length === 0 ? (
            <div className="card flex flex-col items-center justify-center py-12 text-center gap-2">
              <Clock size={24} className="text-[#30363d]" />
              <div className="text-sm text-[#8b949e]">No generation history yet</div>
            </div>
          ) : runs.map(run => (
            <RunHistoryRow key={run.id}
              run={{ ...run, items: runDetails[run.id]?.items }}
              onExpand={handleExpandRun}
              expanded={expandedRun === run.id} />
          ))}
        </div>
      )}
    </div>
  )
}
